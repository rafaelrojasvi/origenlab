{
  "name": "origenlab-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "npm test && npm run build",
    "smoke": "node scripts/smoke-v1.mjs",
    "smoke:sqlite": "EXPECT_BACKEND=sqlite node scripts/smoke-v1.mjs",
    "smoke:postgres": "EXPECT_BACKEND=postgres node scripts/smoke-v1.mjs",
    "smoke:proxy": "SMOKE_BASE_URL=http://127.0.0.1:5173 node scripts/smoke-v1.mjs",
    "smoke:contacts": "node scripts/smoke-v1.mjs",
    "smoke:mirror": "node scripts/mirror-smoke.mjs",
    "freeze:check": "./scripts/run-v1-freeze-checklist.sh",
    "freeze:postgres": "./scripts/run-v1-postgres-matrix-check.sh"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
