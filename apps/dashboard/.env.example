# Dashboard v1 → apps/api (read-only)
#
# Local dev (npm run dev):
#   Leave VITE_ORIGENLAB_API_BASE_URL unset so the Vite proxy forwards
#   /health, /operator, /cases, /opportunities to http://127.0.0.1:8001.
#   Restart `npm run dev` after any .env change.
#
# VITE_ORIGENLAB_API_BASE_URL=
#
# Do NOT point local dev at :8000 (legacy email-pipeline API) — requests will fail.
#
# Production / preview build (npm run build):
#   Required — set to your deployed apps/api host (no trailing slash).
#
# VITE_ORIGENLAB_API_BASE_URL=https://api.example.com
