---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import QuoteCTA from '../../components/QuoteCTA.astro';
import ProductPreviewCard from '../../components/ProductPreviewCard.astro';
import ProductQuoteActions from '../../components/ProductQuoteActions.astro';
import { brands } from '../../data/brands';
import { products } from '../../data/products';

const servaBrand = brands.find((brand) => brand.slug === 'serva-electrophoresis');
const servaProducts = servaBrand
  ? products.filter((product) => product.brandId === servaBrand.id && product.showOnBrandPage)
  : [];
---

<Layout
  title="SERVA Electrophoresis — OrigenLab"
  description="Línea SERVA disponible para cotización con OrigenLab. Productos destacados, aplicaciones y condiciones comerciales confirmadas al cotizar."
>
  <PageHeader
    title="SERVA Electrophoresis"
    lead="Línea especializada para laboratorio, gestionada comercialmente por OrigenLab según necesidad y alcance de cotización."
  />

  {servaBrand ? (
    <>
      <section class="mt-10 rounded-2xl border border-brand-100 bg-gradient-to-br from-brand-50 to-white p-6 shadow-sm md:p-8">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-700">Visión general</p>
            <h2 class="section-title mt-2">{servaBrand.name}</h2>
          </div>
          {servaBrand.logoPath && (
            <img
              src={servaBrand.logoPath}
              alt={servaBrand.logoAlt ?? `Logo ${servaBrand.name}`}
              loading="lazy"
              class="h-12 w-auto object-contain md:h-14"
            />
          )}
        </div>
        {servaBrand.summary && <p class="mt-4 max-w-3xl text-sm leading-relaxed text-slate-600">{servaBrand.summary}</p>}
        {servaBrand.brandIntro && (
          <p class="mt-3 max-w-3xl text-sm leading-relaxed text-slate-600">{servaBrand.brandIntro}</p>
        )}
        <p class="mt-3 max-w-3xl text-xs leading-relaxed text-slate-500">
          Pedidos gestionados por OrigenLab según confirmación comercial. Disponibilidad y condiciones
          se validan al cotizar; no implica stock permanente ni distribución exclusiva.
        </p>
        <div class="mt-6">
          <ProductQuoteActions brandName={servaBrand.homeCardTitle ?? 'SERVA Electrophoresis'} />
        </div>
      </section>

      {servaBrand.applicationAreas && servaBrand.applicationAreas.length > 0 && (
        <section class="mt-12" aria-labelledby="aplicaciones-heading">
          <h2 id="aplicaciones-heading" class="section-title">Áreas de aplicación</h2>
          <ul class="mt-6 grid gap-4 md:grid-cols-3">
            {servaBrand.applicationAreas.map((area) => (
              <li class="card-elevated border-l-4 border-l-brand-500">
                <p class="font-semibold text-brand-950">{area}</p>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section class="mt-12" aria-labelledby="productos-destacados-heading">
        <h2 id="productos-destacados-heading" class="section-title">Productos destacados</h2>
        <p class="mt-2 max-w-2xl text-sm text-slate-600">
          Referencias seleccionadas para consulta comercial. La disponibilidad final y condiciones se validan durante la cotización.
        </p>
        <ul class="mt-6 grid gap-4 md:grid-cols-3">
          {servaProducts.map((product) => (
            <li>
              <ProductPreviewCard product={product} showApplication={true} showCommercialNote={true} />
            </li>
          ))}
        </ul>
      </section>

      <section class="mt-12 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm" aria-labelledby="condiciones-heading">
        <h2 id="condiciones-heading" class="section-title">Condiciones comerciales</h2>
        <p class="mt-3 text-sm leading-relaxed text-slate-600">
          OrigenLab puede gestionar pedidos directos con SERVA según confirmación comercial. La modalidad de prepago aplica y la
          disponibilidad, documentación técnica y condiciones se confirman al cotizar.
        </p>
      </section>
    </>
  ) : (
    <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-slate-600">
        Esta línea se encuentra en actualización. Contáctenos para confirmar disponibilidad y opciones de cotización.
      </p>
    </section>
  )}

  <section class="mt-14">
    <QuoteCTA
      title="¿Quiere cotizar productos SERVA?"
      description="Comparta su necesidad y le confirmamos alcance comercial, disponibilidad y documentación aplicable."
    />
  </section>
</Layout>
