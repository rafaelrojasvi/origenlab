---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import QuoteCTA from '../../components/QuoteCTA.astro';
import ProductPreviewCard from '../../components/ProductPreviewCard.astro';
import ProductQuoteActions from '../../components/ProductQuoteActions.astro';
import { getBrandBySlug, getProductsByBrandId } from '../../lib/catalog';

const brand = getBrandBySlug('ortoalresa');
const brandProducts = brand
  ? getProductsByBrandId(brand.id)
      .filter((product) => product.showOnBrandPage)
      .sort((a, b) => (a.catalogSortOrder ?? 999) - (b.catalogSortOrder ?? 999))
  : [];
const microcentrifugas = brandProducts.filter((p) => p.productGroup === 'microcentrifugas');
const universalesGranCapacidad = brandProducts.filter(
  (p) => p.productGroup === 'universales-gran-capacidad',
);
---

<Layout
  title="Ortoalresa | Centrífugas de laboratorio | OrigenLab"
  description="Centrífugas Ortoalresa para evaluación técnica y cotización a través de OrigenLab. Disponible bajo cotización; condiciones sujetas a confirmación comercial."
>
  <PageHeader
    title="Ortoalresa"
    lead={brand?.pageSubtitle ?? 'Centrífugas de laboratorio para aplicaciones generales y especializadas'}
  />

  {brand ? (
    <>
      <section class="mt-10 rounded-2xl border border-brand-100 bg-gradient-to-br from-brand-50 to-white p-6 shadow-sm md:p-8">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-700">Fabricante</p>
            <h2 class="section-title mt-2">{brand.name}</h2>
            {brand.legalName && (
              <p class="mt-1 text-xs text-slate-500">
                <span class="font-medium text-slate-600">Fabricante / referencia comercial:</span>{' '}
                {brand.legalName}
              </p>
            )}
          </div>
          {brand.logoPath && (
            <img
              src={brand.logoPath}
              alt={brand.logoAlt ?? `Logo ${brand.name}`}
              loading="lazy"
              class="h-12 w-auto object-contain md:h-14"
            />
          )}
        </div>
        {brand.summary && (
          <p class="mt-4 max-w-3xl text-sm leading-relaxed text-slate-600">{brand.summary}</p>
        )}
        {brand.manufacturerAttribution && (
          <p class="mt-3 max-w-3xl text-xs leading-relaxed text-slate-500">{brand.manufacturerAttribution}</p>
        )}
        {brand.websiteUrl && (
          <p class="mt-4 text-sm">
            <a
              href={brand.websiteUrl}
              class="font-medium text-brand-700 hover:text-brand-800"
              rel="noopener noreferrer"
              target="_blank"
            >
              Sitio del fabricante (referencia técnica) →
            </a>
          </p>
        )}
        <div class="mt-6">
          <ProductQuoteActions brandName={brand.name} />
        </div>
      </section>

      {microcentrifugas.length > 0 && (
        <section class="mt-12" aria-labelledby="micro-heading">
          <h2 id="micro-heading" class="section-title">Microcentrífugas</h2>
          <ul class="mt-6 grid gap-4 md:grid-cols-2">
            {microcentrifugas.map((product) => (
              <li>
                <ProductPreviewCard
                  product={product}
                  showApplication={true}
                  showCommercialNote={true}
                  showImage={true}
                  showWhatsApp={true}
                  brandNameForQuote={brand.name}
                />
              </li>
            ))}
          </ul>
        </section>
      )}

      {universalesGranCapacidad.length > 0 && (
        <section class="mt-12" aria-labelledby="universal-heading">
          <h2 id="universal-heading" class="section-title">Centrífugas universales y gran capacidad</h2>
          <ul class="mt-6 grid gap-4 md:grid-cols-2">
            {universalesGranCapacidad.map((product) => (
              <li>
                <ProductPreviewCard
                  product={product}
                  showApplication={true}
                  showCommercialNote={true}
                  showImage={true}
                  showWhatsApp={true}
                  brandNameForQuote={brand.name}
                />
              </li>
            ))}
          </ul>
        </section>
      )}

      <p class="mt-6 text-sm">
        <a href="/productos/centrifugas" class="font-medium text-brand-700 hover:text-brand-800">
          Ver familia Centrífugas →
        </a>
      </p>

      <section class="mt-12 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm" aria-labelledby="condiciones-heading">
        <h2 id="condiciones-heading" class="section-title">Condiciones comerciales</h2>
        <p class="mt-3 text-sm leading-relaxed text-slate-600">
          {brand.commercialNote ??
            'Disponible bajo cotización. Cotización y disponibilidad sujetas a confirmación comercial.'}
        </p>
        <p class="mt-3 text-sm leading-relaxed text-slate-600">
          La configuración, accesorios, disponibilidad, garantía y condiciones comerciales se confirman en la cotización.
        </p>
      </section>
    </>
  ) : (
    <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-slate-600">
        Esta línea se encuentra en actualización. Contáctenos para confirmar opciones de cotización.
      </p>
    </section>
  )}

  <section class="mt-14">
    <QuoteCTA
      title="¿Quiere cotizar centrífugas Ortoalresa?"
      description="Indique aplicación, tipo de muestra y configuración deseada. Respondemos por correo o WhatsApp."
    />
  </section>
</Layout>
