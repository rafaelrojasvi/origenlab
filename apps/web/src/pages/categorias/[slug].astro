---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import QuoteCTA from '../../components/QuoteCTA.astro';
import { categories } from '../../data/categories';
import { company } from '../../data/company';
import ProductPreviewCard from '../../components/ProductPreviewCard.astro';
import { getBrandById, getCategoryRelatedProducts } from '../../lib/catalog';
import { buildWhatsAppQuoteUrl } from '../../lib/whatsapp';

export function getStaticPaths() {
  return categories.map((cat) => ({ params: { slug: cat.slug } }));
}

const { slug } = Astro.params;
const category = categories.find((c) => c.slug === slug);
if (!category) return Astro.redirect('/productos');

const metaDescription = `${category.name}. ${category.description ?? ''} ${company.oneLiner} Cotización: correo y WhatsApp.`.slice(0, 158);
const relatedProducts = getCategoryRelatedProducts(category.slug);
const isLaboratorioClinico = category.slug === 'laboratorio-clinico';
const ortoalresaCentrifugeQuoteHref = buildWhatsAppQuoteUrl({ brandName: 'Ortoalresa' });
---

<Layout title={`${category.name} — OrigenLab`} description={metaDescription}>
  <PageHeader title={category.name} lead={category.description} />

  <div class="mt-8 space-y-6 text-slate-700">
    <p class="max-w-2xl leading-relaxed">{category.buyerGuide}</p>
    <div class="rounded-lg border border-slate-100 bg-slate-50/80 p-5">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">
        Antes de cotizar
      </h2>
      <ul class="mt-3 list-inside list-disc space-y-2 text-sm text-slate-600">
        {category.buyerBullets.map((b) => (
          <li>{b}</li>
        ))}
      </ul>
    </div>
    <p class="text-sm text-slate-600">{company.catalogNote}</p>

    {relatedProducts.length > 0 && (
      <section class="mt-10" aria-labelledby="equipos-relacionados-heading">
        <h2 id="equipos-relacionados-heading" class="text-sm font-semibold uppercase tracking-wide text-slate-500">
          Equipos relacionados (cotización)
        </h2>
        <p class="mt-2 max-w-2xl text-sm text-slate-600">
          Centrífugas Ortoalresa para preparación de muestras y análisis en control de calidad, según
          configuración y requerimientos del laboratorio.
        </p>
        <ul class="mt-4 grid gap-4 sm:grid-cols-2">
          {relatedProducts.map((product) => {
            const brand = getBrandById(product.brandId);
            return (
              <li>
                <ProductPreviewCard
                  product={product}
                  brandName={brand?.name}
                  showBrand={true}
                  showImage={Boolean(product.imagePath)}
                  showWhatsApp={true}
                  brandNameForQuote="Ortoalresa"
                />
              </li>
            );
          })}
        </ul>
        <p class="mt-3 text-sm">
          <a href="/productos/centrifugas" class="font-medium text-brand-700 hover:text-brand-800">
            Ver familia Centrífugas →
          </a>
        </p>
      </section>
    )}

    {isLaboratorioClinico && (
      <section
        class="mt-10 rounded-xl border border-brand-100 bg-brand-50/40 p-5 md:p-6"
        aria-labelledby="centrifugas-clinico-callout-heading"
      >
        <h2
          id="centrifugas-clinico-callout-heading"
          class="text-sm font-semibold uppercase tracking-wide text-slate-500"
        >
          Equipamiento de apoyo
        </h2>
        <p class="mt-3 max-w-2xl text-sm leading-relaxed text-slate-600">
          Algunos modelos de centrífugas pueden evaluarse para preparación de muestras en laboratorio
          clínico según configuración y requerimientos del laboratorio. No implica certificación
          clínica ni idoneidad diagnóstica sin confirmación del responsable técnico y del fabricante.
        </p>
        <div class="mt-5 flex flex-col gap-3 sm:flex-row">
          <a href="/productos/centrifugas" class="btn-outline-dark text-center">
            Ver centrífugas Ortoalresa
          </a>
          <a
            href={ortoalresaCentrifugeQuoteHref}
            class="btn-whatsapp text-center"
            target="_blank"
            rel="noopener noreferrer"
          >
            Cotizar por WhatsApp
          </a>
        </div>
      </section>
    )}

    <QuoteCTA
      title={`Cotizar: ${category.name}`}
      description="Correo o WhatsApp — indique laboratorio, ciudad y lo que busca."
    />
  </div>

  <p class="mt-10">
    <a href="/productos" class="link-muted text-sm font-medium">← Volver a productos</a>
  </p>
</Layout>
