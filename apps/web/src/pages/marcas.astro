---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import QuoteCTA from '../components/QuoteCTA.astro';
import { brands } from '../data/brands';
import { company } from '../data/company';
import { site } from '../config/site';
import { products } from '../data/products';
import { productPageHref } from '../lib/catalog';

const homeBrands = brands.filter((brand) => brand.showOnHomeBrandsSection);

function brandProducts(brandId: string) {
  return products.filter((product) => product.brandId === brandId && product.showOnBrandPage);
}
---

<Layout
  title="Marcas — OrigenLab"
  description={`Líneas y marcas disponibles según alcance comercial. ${company.primaryOffer}, atención en ${company.geography}. ${site.location}.`}
>
  <PageHeader
    title="Marcas"
    lead="Trabajamos con líneas y marcas según alcance comercial vigente. La disponibilidad, documentación y condiciones se confirman durante la cotización."
  />

  <section class="mt-10" aria-labelledby="marcas-intro-heading">
    <h2 id="marcas-intro-heading" class="section-title">Marcas y líneas para cotización</h2>
    <p class="mt-3 max-w-3xl text-slate-600">
      Si busca una marca en particular, cotización o recomendación según su laboratorio, escríbanos.
      Definimos alcance, condiciones comerciales y documentación técnica durante el proceso de cotización.
    </p>
  </section>

  <ul class="mt-8 grid gap-4 sm:grid-cols-2">
    {homeBrands.map((brand) => {
      const items = brandProducts(brand.id);
      return (
        <li class="card-elevated flex h-full flex-col border border-brand-100">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="font-semibold text-brand-950">{brand.homeCardTitle ?? brand.name}</h3>
            </div>
            {brand.logoPath && (
              <img
                src={brand.logoPath}
                alt={brand.logoAlt ?? brand.name}
                loading="lazy"
                class="h-10 w-auto shrink-0 object-contain md:h-12"
              />
            )}
          </div>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">
            {brand.homeCardDescription ?? brand.summary}
          </p>
          {items.length > 0 && (
            <ul class="mt-4 space-y-1.5 text-sm text-slate-600">
              {items.slice(0, 5).map((product) => (
                <li>
                  <a
                    href={productPageHref(product) ?? `/marcas/${brand.slug}`}
                    class="font-medium text-brand-700 hover:text-brand-800"
                  >
                    {product.name}
                  </a>
                </li>
              ))}
              {items.length > 5 && <li class="text-slate-500">y más modelos en la ficha de marca</li>}
            </ul>
          )}
          <div class="mt-auto flex flex-col gap-2 pt-5">
            <a href={`/marcas/${brand.slug}`} class="btn-outline-dark text-center">
              {brand.homeCardCtaLabel ?? `Ver ${brand.name}`}
            </a>
          </div>
        </li>
      );
    })}
  </ul>

  <div class="mt-14">
    <QuoteCTA
      title="¿Marca o equipo específico?"
      description="Consúltenos por disponibilidad y condiciones; respondemos por correo o WhatsApp."
    />
  </div>
</Layout>
