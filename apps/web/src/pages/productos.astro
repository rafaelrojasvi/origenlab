---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import QuoteCTA from '../components/QuoteCTA.astro';
import Card from '../components/Card.astro';
import ProductPreviewCard from '../components/ProductPreviewCard.astro';
import BrandSkuCard from '../components/BrandSkuCard.astro';
import { categories } from '../data/categories';
import { company } from '../data/company';
import { getBrandById, getOrtoalresaCentrifuges, getProductsByBrandId } from '../lib/catalog';
import { buildWhatsAppQuoteUrl } from '../lib/whatsapp';
import { ctaLabels } from '../lib/ctaLabels';

const ortoalresaCentrifuges = getOrtoalresaCentrifuges().filter((p) => p.showOnProductsPage);
const servaBrand = getBrandById('serva');
const servaProducts = servaBrand
  ? getProductsByBrandId(servaBrand.id).filter((p) => p.showOnProductsPage)
  : [];
const servaBrandName = servaBrand?.homeCardTitle ?? servaBrand?.name ?? 'SERVA Electrophoresis';
const servaBrandHref = servaBrand ? `/marcas/${servaBrand.slug}` : '/marcas';
const ortoalresaQuoteHref = buildWhatsAppQuoteUrl({ brandName: 'Ortoalresa' });
---

<Layout
  title="Productos — OrigenLab"
  description={`Equipos para alimentos, control de calidad y laboratorio clínico. ${company.catalogNote}`}
>
  <PageHeader
    title="Productos"
    lead={`${company.primaryOffer} en tres categorías. ${company.catalogNote}`}
  />

  <div class="mt-10">
    <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((cat) => (
        <li>
          <Card
            title={cat.name}
            href={`/categorias/${cat.slug}`}
            description={cat.description}
          />
        </li>
      ))}
    </ul>
  </div>

  <section class="mt-14" aria-labelledby="lineas-cotizacion-heading">
    <h2 id="lineas-cotizacion-heading" class="section-title">
      Líneas y productos disponibles para cotización
    </h2>
    <p class="mt-2 max-w-2xl text-sm leading-relaxed text-slate-600">
      Cotización y disponibilidad sujetas a confirmación comercial. La configuración, accesorios y
      condiciones comerciales se confirman en la cotización.
    </p>

    {ortoalresaCentrifuges.length > 0 && (
      <section class="mt-10" aria-labelledby="ortoalresa-centrifugas-heading">
        <div class="rounded-2xl border border-brand-100 bg-gradient-to-br from-brand-50/80 to-white p-6 shadow-sm md:p-8">
          <h3 id="ortoalresa-centrifugas-heading" class="text-lg font-bold text-brand-950">
            Centrífugas Ortoalresa
          </h3>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-slate-600">
            Microcentrífugas y centrífugas ventiladas o refrigeradas para preparación de muestras.
            Equipos disponibles para evaluación técnica y cotización a través de OrigenLab.
          </p>
          <div class="mt-5 flex flex-col gap-3 sm:flex-row">
            <a href="/productos/centrifugas" class="btn-primary text-center">Ver línea completa</a>
            <a
              href={ortoalresaQuoteHref}
              class="btn-whatsapp text-center"
              target="_blank"
              rel="noopener noreferrer"
            >
              {ctaLabels.quoteLine}
            </a>
          </div>
          <ul class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
            {ortoalresaCentrifuges.map((product) => (
              <li class="h-full">
                <ProductPreviewCard
                  product={product}
                  brandName="Ortoalresa"
                  showBrand={true}
                  showApplication={true}
                  showImage={true}
                  showWhatsApp={true}
                  brandNameForQuote="Ortoalresa"
                />
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    {servaProducts.length > 0 && (
      <section class="mt-10" aria-labelledby="serva-linea-heading">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
          <h3 id="serva-linea-heading" class="text-lg font-bold text-brand-950">
            Reactivos y soluciones SERVA
          </h3>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-slate-600">
            Referencias para electroforesis y preparación de muestras. Pedidos gestionados por OrigenLab
            según confirmación comercial; disponibilidad y condiciones se validan al cotizar.
          </p>
          <p class="mt-3">
            <a href={servaBrandHref} class="text-sm font-semibold text-brand-700 hover:text-brand-800">
              Ver línea SERVA →
            </a>
          </p>
          <ul class="mt-6 grid gap-4 md:grid-cols-3">
            {servaProducts.map((product) => (
              <li class="h-full">
                <BrandSkuCard
                  product={product}
                  brandName={servaBrandName}
                  brandHref={servaBrandHref}
                  brandLineLabel="Ver línea SERVA"
                />
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}
  </section>

  <div class="mt-14">
    <QuoteCTA
      title="¿Busca un equipo en particular?"
      description="Consulte por disponibilidad y cotización; sin compromiso."
    />
  </div>
</Layout>
