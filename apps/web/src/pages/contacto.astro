---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { site } from '../config/site';
import { contact, whatsappUrl, telUrl } from '../data/contact';
import { buildQuoteMailtoUrl } from '../lib/whatsapp';
import { ctaLabels } from '../lib/ctaLabels';

const mailtoHref = buildQuoteMailtoUrl();
import { company } from '../data/company';
---

<Layout
  title="Contacto — OrigenLab"
  description={`${site.name}: ${contact.email} · ${contact.phoneDisplay} · ${site.location} · Lun–vie ${site.hours} · Atención en ${company.geography}.`}
>
  <PageHeader
    title="Contacto"
    lead="Cotizaciones y consultas por correo, teléfono o WhatsApp. Atención en todo Chile."
  />

  <div class="mt-10 rounded-2xl border border-brand-100 bg-white p-8 shadow-sm">
    <dl class="space-y-4 text-slate-700">
      <div>
        <dt class="font-medium text-slate-900">Correo</dt>
        <dd>
          <a href={`mailto:${site.email}`} class="link-muted">{site.email}</a>
        </dd>
      </div>
      <div>
        <dt class="font-medium text-slate-900">Teléfono</dt>
        <dd>
          <a href={telUrl()} class="link-muted">{contact.phoneDisplay}</a>
        </dd>
      </div>
      <div>
        <dt class="font-medium text-slate-900">WhatsApp</dt>
        <dd>
          <a href={whatsappUrl()} class="link-muted" target="_blank" rel="noopener noreferrer"
            >WhatsApp</a
          >
        </dd>
      </div>
      <div>
        <dt class="font-medium text-slate-900">Ubicación</dt>
        <dd>{site.location}</dd>
      </div>
      <div>
        <dt class="font-medium text-slate-900">Horario</dt>
        <dd class="text-slate-600">Lun–vie {site.hours}</dd>
      </div>
    </dl>
    <p class="mt-6 flex flex-wrap gap-3">
      <a href={mailtoHref} class="btn-primary" aria-label={ctaLabels.solicitarCotizacion}>
        {ctaLabels.solicitarCotizacion}
      </a>
      <a
        href={whatsappUrl()}
        class="btn-whatsapp"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={ctaLabels.whatsapp}
      >
        {ctaLabels.whatsapp}
      </a>
    </p>
  </div>
</Layout>
