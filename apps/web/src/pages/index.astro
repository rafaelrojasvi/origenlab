---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import QuoteCTA from '../components/QuoteCTA.astro';
import Card from '../components/Card.astro';
import { site } from '../config/site';
import { company } from '../data/company';
import { categories } from '../data/categories';
import { serviceOfferings } from '../data/services';
import { faqItems } from '../data/faq';
import { brands } from '../data/brands';
import { products } from '../data/products';
import ProductPreviewCard from '../components/ProductPreviewCard.astro';

const featuredBrand = brands.find((brand) => brand.featuredOnHome);
const featuredBrandProducts = featuredBrand
  ? products.filter((product) => product.brandId === featuredBrand.id && product.showOnHome)
  : [];
---

<Layout
  title={`${site.name} — ${site.tagline}`}
  description={site.description}
>
  <Hero
    title={site.tagline}
    subtitle={company.heroSubtitle}
    ctaText="Solicitar cotización"
    ctaHref="/contacto"
    ctaSecondaryText="Ver equipos por categoría"
    ctaSecondaryHref="/productos"
  />

  <section class="border-b border-slate-100 py-10" aria-labelledby="intro-heading">
    <h2 id="intro-heading" class="sr-only">Sobre OrigenLab</h2>
    <p class="mx-auto max-w-3xl text-center text-slate-600">{company.homeIntro}</p>
  </section>

  <section class="py-12" aria-labelledby="why-heading">
    <h2 id="why-heading" class="section-title">Por qué contactarnos</h2>
    <ul class="mt-8 grid gap-6 sm:grid-cols-3">
      {company.valueProps.map((item) => (
        <li class="card-elevated rounded-xl border-l-4 border-l-brand-500">
          <h3 class="font-bold text-brand-950">{item.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">{item.text}</p>
        </li>
      ))}
    </ul>
  </section>

  <section class="py-12" aria-labelledby="categories-heading">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 id="categories-heading" class="section-title">Equipos por categoría</h2>
        <p class="mt-2 text-slate-600">
          Tres líneas. Entra a la que te corresponda y pide cotización con contexto.
        </p>
      </div>
      <a href="/contacto" class="text-sm font-bold text-brand-700 hover:text-brand-800">
        Ir a contacto →
      </a>
    </div>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((cat) => (
        <Card
          title={cat.name}
          href={`/categorias/${cat.slug}`}
          description={cat.description}
        />
      ))}
    </div>
  </section>

  {featuredBrand && (
    <section class="py-12" aria-labelledby="featured-brand-heading">
      <div class="rounded-2xl border border-brand-100 bg-gradient-to-br from-brand-50 to-white p-6 shadow-sm md:p-8">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-700">Marca destacada</p>
            <h2 id="featured-brand-heading" class="section-title mt-2">{featuredBrand.name}</h2>
            {featuredBrand.featuredIntro && (
              <p class="mt-2 max-w-2xl text-sm leading-relaxed text-slate-600">{featuredBrand.featuredIntro}</p>
            )}
          </div>
          {featuredBrand.logoPath && (
            <img
              src={featuredBrand.logoPath}
              alt={featuredBrand.logoAlt ?? `Logo ${featuredBrand.name}`}
              loading="lazy"
              class="h-12 w-auto object-contain md:h-14"
            />
          )}
        </div>

        {featuredBrandProducts.length > 0 && (
          <ul class="mt-6 grid gap-4 md:grid-cols-3">
            {featuredBrandProducts.map((product) => (
              <li class="h-full">
                <ProductPreviewCard product={product} />
              </li>
            ))}
          </ul>
        )}

        <p class="mt-5 max-w-3xl text-sm text-slate-600">
          {featuredBrand.commercialNote ??
            'Disponibilidad, condiciones comerciales y documentación técnica se confirman durante la cotización.'}
        </p>
        <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a href={`/marcas/${featuredBrand.slug}`} class="btn-outline-dark">Ver línea SERVA</a>
          <a href="/contacto" class="btn-primary">Solicitar cotización</a>
        </div>
      </div>
    </section>
  )}

  <section class="py-12" aria-labelledby="services-heading">
    <h2 id="services-heading" class="section-title">Qué incluye trabajar con OrigenLab</h2>
    <p class="mt-2 max-w-2xl text-sm text-slate-600">
      Lo concreto depende del equipo y del acuerdo; esto es lo que ofrecemos como marco comercial.
    </p>
    <ul class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {serviceOfferings.map((s) => (
        <li class="card-elevated rounded-xl">
          <h3 class="font-bold text-brand-900">{s.name}</h3>
          <p class="mt-1 text-sm text-slate-600">{s.shortDescription}</p>
        </li>
      ))}
    </ul>
    <p class="mt-4 text-sm text-slate-600">{company.catalogNote}</p>
  </section>

  <section class="py-12" aria-labelledby="faq-heading">
    <h2 id="faq-heading" class="section-title">Preguntas frecuentes</h2>
    <div
      class="mt-8 divide-y divide-slate-100 rounded-2xl border border-slate-200/80 bg-white shadow-sm"
      role="region"
      aria-label="Preguntas frecuentes"
    >
      {faqItems.map((item) => (
        <details class="group px-4 py-3 open:bg-slate-50/50" name="faq">
          <summary
            class="cursor-pointer list-none rounded font-medium text-slate-900 marker:content-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2 [&::-webkit-details-marker]:hidden"
          >
            <span class="flex items-center justify-between gap-2">
              {item.question}
              <span class="text-slate-400 motion-safe:transition group-open:rotate-180" aria-hidden="true"
                >▼</span
              >
            </span>
          </summary>
          <p class="mt-2 pb-1 text-sm leading-relaxed text-slate-600">{item.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="py-12">
    <QuoteCTA
      title="Solicitar cotización"
      description="Un solo paso: contacto con correo, WhatsApp y datos de ubicación."
    />
  </section>
</Layout>
