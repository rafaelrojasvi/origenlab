---
import Layout from '../layouts/Layout.astro';
import HomeHero from '../components/HomeHero.astro';
import HomeCommercialLines from '../components/HomeCommercialLines.astro';
import HomeCategoryCards from '../components/HomeCategoryCards.astro';
import HomeProcess from '../components/HomeProcess.astro';
import HomeFinalCTA from '../components/HomeFinalCTA.astro';
import { site } from '../config/site';
import { faqItems } from '../data/faq';
---

<Layout
  title={`${site.name} — ${site.tagline}`}
  description={site.description}
  mainClass="mx-auto max-w-7xl px-5 pb-16 pt-0 md:px-6 md:pb-20"
>
  <HomeHero />

  <div class="space-y-2 md:space-y-4">
    <HomeCommercialLines />
    <HomeCategoryCards />
    <HomeProcess />

    <section class="home-section" aria-labelledby="faq-heading">
      <header class="max-w-2xl">
        <h2 id="faq-heading" class="text-2xl font-bold tracking-tight text-brand-950 md:text-3xl">
          Preguntas frecuentes
        </h2>
        <p class="mt-2 text-sm text-slate-600">Respuestas breves sobre cotización y atención comercial.</p>
      </header>
      <div
        class="mt-8 divide-y divide-slate-100 overflow-hidden rounded-2xl border border-slate-200/60 bg-white shadow-sm"
        role="region"
        aria-label="Preguntas frecuentes"
      >
        {
          faqItems.map((item) => (
            <details class="group px-5 py-4 open:bg-slate-50/60" name="faq">
              <summary
                class="cursor-pointer list-none text-sm font-semibold text-slate-900 marker:content-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 [&::-webkit-details-marker]:hidden"
              >
                <span class="flex items-center justify-between gap-3">
                  {item.question}
                  <span
                    class="shrink-0 text-slate-400 motion-safe:transition group-open:rotate-180"
                    aria-hidden="true"
                  >
                    ▼
                  </span>
                </span>
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-slate-600">{item.answer}</p>
            </details>
          ))
        }
      </div>
    </section>

    <HomeFinalCTA />
  </div>
</Layout>
