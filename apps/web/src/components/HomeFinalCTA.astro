---
import { buildQuoteMailtoUrl } from '../lib/whatsapp';
import { whatsappUrl } from '../data/contact';
import { ctaLabels } from '../lib/ctaLabels';

const mailtoHref = buildQuoteMailtoUrl();
---

<section class="home-section pb-4" aria-labelledby="home-final-cta-heading">
  <div class="home-final-cta">
    <div
      class="pointer-events-none absolute inset-0 opacity-20"
      style="background-image: radial-gradient(circle at 100% 0%, #99f6e4 0%, transparent 50%);"
      aria-hidden="true"
    />
    <div class="relative max-w-2xl">
      <h2 id="home-final-cta-heading" class="text-2xl font-bold tracking-tight md:text-3xl">
        ¿Necesita cotizar un equipo o línea de laboratorio?
      </h2>
      <p class="mt-4 text-base leading-relaxed text-brand-100/95">
        Escríbanos con el tipo de laboratorio, aplicación o equipo que busca. Le responderemos con
        orientación comercial y técnica según disponibilidad.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <a
          href={whatsappUrl()}
          class="inline-flex items-center justify-center rounded-lg bg-emerald-500 px-6 py-3 text-sm font-bold text-white shadow-md transition hover:bg-emerald-400"
          target="_blank"
          rel="noopener noreferrer"
        >
          {ctaLabels.whatsapp}
        </a>
        <a
          href={mailtoHref}
          class="inline-flex items-center justify-center rounded-lg bg-white px-6 py-3 text-sm font-bold text-brand-900 shadow-md transition hover:bg-brand-50"
        >
          Enviar correo
        </a>
        <a
          href="/contacto"
          class="inline-flex items-center justify-center rounded-lg border-2 border-white/35 px-6 py-3 text-sm font-bold text-white transition hover:bg-white/10"
        >
          Ir a contacto
        </a>
      </div>
    </div>
  </div>
</section>
