---
import type { ProductSpec } from '../data/products';

interface Props {
  specs: readonly ProductSpec[];
  attribution?: string;
}

const { specs, attribution } = Astro.props;
---

<div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
  <div class="overflow-x-auto overscroll-x-contain [-webkit-overflow-scrolling:touch]" tabindex="0" role="region" aria-label="Especificaciones del producto">
    <table class="w-full min-w-[280px] text-left text-xs sm:text-sm">
      <tbody class="divide-y divide-slate-100">
        {specs.map((spec) => (
          <tr class="even:bg-slate-50/60">
            <th scope="row" class="w-[38%] px-3 py-2.5 font-medium text-slate-700 sm:w-[42%] sm:px-4 sm:py-3">
              {spec.label}
            </th>
            <td class="break-words px-3 py-2.5 text-slate-600 sm:px-4 sm:py-3">{spec.value}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  {attribution && <p class="border-t border-slate-100 px-4 py-3 text-xs text-slate-500">{attribution}</p>}
</div>
