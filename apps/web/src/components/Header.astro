---
import { site } from '../config/site';
import { ctaLabels } from '../lib/ctaLabels';
import OrigenLogoLockupAnimated from './logo/OrigenLogoLockupAnimated.astro';
---

<header
  class="sticky top-0 z-50 border-b border-brand-800/40 bg-brand-950/95 shadow-lg shadow-brand-950/25 backdrop-blur-md"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-3 px-5 py-3.5 lg:px-8 lg:py-4">
    <a
      href="/"
      class="nav-link-invert shrink-0 rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/80 focus-visible:ring-offset-2 focus-visible:ring-offset-brand-900"
      aria-label={`${site.name}, inicio`}
    >
      <OrigenLogoLockupAnimated
        variant="dark"
        size="md"
        solution="premium"
        motion="header"
        gap="tight"
        decorative
      />
    </a>

    <div class="flex items-center gap-2 sm:gap-3">
      <nav
        class="hidden items-center gap-1 md:flex"
        aria-label="Navegación principal"
      >
        {
          site.nav.map((item) => (
            <a
              href={item.href}
              class="nav-link-invert rounded-lg px-3 py-2 text-sm font-semibold"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <a
        href="/contacto"
        class="hidden rounded-lg bg-white px-4 py-2 text-sm font-bold text-brand-900 shadow-sm transition hover:bg-brand-50 sm:inline-flex"
      >
        Cotizar
      </a>

      <details class="group relative md:hidden">
        <summary
          class="nav-link-invert list-none cursor-pointer rounded-lg border border-white/20 px-3 py-2 text-sm font-semibold marker:content-none [&::-webkit-details-marker]:hidden"
        >
          Menú
        </summary>
        <nav
          class="absolute right-0 top-full z-50 mt-2 min-w-[12rem] rounded-xl border border-brand-700/50 bg-brand-950 py-2 shadow-xl"
          aria-label="Navegación móvil"
        >
          {
            site.nav.map((item) => (
              <a
                href={item.href}
                class="block px-4 py-2.5 text-sm font-semibold text-white/90 hover:bg-white/10 hover:text-white"
              >
                {item.label}
              </a>
            ))
          }
          <a
            href="/contacto"
            class="mx-2 mt-1 block rounded-lg bg-white px-3 py-2 text-center text-sm font-bold text-brand-900"
          >
            {ctaLabels.solicitarCotizacion}
          </a>
        </nav>
      </details>
    </div>
  </div>
</header>
