---
interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  ctaSecondaryText?: string;
  ctaSecondaryHref?: string;
}

const { title, subtitle, ctaText, ctaHref, ctaSecondaryText, ctaSecondaryHref } = Astro.props;
---

{/* Full-bleed hero: ancho viewport, sin copiar HTML de terceros */}
<section
  class="relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen overflow-hidden bg-gradient-to-br from-brand-800 via-brand-700 to-brand-900 py-16 text-center md:py-20"
  aria-labelledby="hero-title"
>
  {/* Textura sutil */}
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.07]"
    style={`background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");`}
    aria-hidden="true"
  />
  <div class="relative mx-auto max-w-3xl px-6">
    <p class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-brand-200">
      OrigenLab
    </p>
    <h1
      id="hero-title"
      class="text-3xl font-bold leading-tight tracking-tight text-white md:text-4xl lg:text-[2.5rem]"
    >
      {title}
    </h1>
    {subtitle && (
      <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-brand-100 md:text-lg">
        {subtitle}
      </p>
    )}
    {(ctaText && ctaHref) || (ctaSecondaryText && ctaSecondaryHref) ? (
      <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row sm:flex-wrap">
        {ctaText && ctaHref && (
          <a href={ctaHref} class="btn-primary-light min-w-[11rem] px-8 py-3.5 text-center" aria-label="Solicitar cotización: ir a contacto">
            {ctaText}
          </a>
        )}
        {ctaSecondaryText && ctaSecondaryHref && (
          <a href={ctaSecondaryHref} class="btn-outline min-w-[11rem] px-8 py-3.5 text-center">
            {ctaSecondaryText}
          </a>
        )}
      </div>
    ) : null}
  </div>
  {/* Onda inferior → contenido blanco/gris del sitio */}
  <div class="absolute bottom-0 left-0 right-0 translate-y-px leading-none">
    <svg
      class="block w-full text-slate-50"
      viewBox="0 0 1440 48"
      fill="currentColor"
      preserveAspectRatio="none"
      aria-hidden="true"
    >
      <path
        d="M0,24 C240,48 480,0 720,20 C960,40 1200,8 1440,28 L1440,48 L0,48 Z"
      />
    </svg>
  </div>
</section>
