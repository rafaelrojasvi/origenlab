---
import type { Product } from '../data/products';
import { productPageHref } from '../lib/catalog';
import {
  getComparisonRows,
  getShowcaseApplication,
  getShowcaseSpecChips,
} from '../lib/productShowcase';
import { buildWhatsAppQuoteUrl } from '../lib/whatsapp';
import { ctaLabels } from '../lib/ctaLabels';

interface Props {
  title: string;
  subtitle: string;
  products: Product[];
  familyHref?: string;
  brandName?: string;
  commercialNote?: string;
  configurationNote?: string;
  showComparison?: boolean;
}

const {
  title,
  subtitle,
  products,
  familyHref = '/productos/centrifugas',
  brandName = 'Ortoalresa',
  commercialNote = 'Cotización y disponibilidad sujetas a confirmación comercial.',
  configurationNote = 'La configuración, accesorios y condiciones comerciales se confirman en la cotización.',
  showComparison = true,
} = Astro.props;

const sectionId = 'product-showcase-heading';
const brandWhatsappHref = buildWhatsAppQuoteUrl({ brandName });
const comparisonRows = showComparison ? getComparisonRows(products) : [];
---

<section class="py-14" aria-labelledby={sectionId}>
  <div class="showcase-panel rounded-2xl border border-slate-200/90 p-6 shadow-sm md:p-10">
    <header class="max-w-3xl">
      <h2 id={sectionId} class="section-title text-brand-950">{title}</h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-600 md:text-base">{subtitle}</p>
      <p class="mt-3 text-xs text-slate-500">{commercialNote}</p>
    </header>

    <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      <a href={familyHref} class="btn-primary text-center">Ver línea completa</a>
      <a
        href={brandWhatsappHref}
        class="btn-whatsapp text-center"
        target="_blank"
        rel="noopener noreferrer"
      >
        {ctaLabels.whatsapp}
      </a>
    </div>

    <ul class="showcase-product-grid mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-6">
      {
        products.map((product, index) => {
          const href = productPageHref(product);
          const chips = getShowcaseSpecChips(product);
          const applicationLine = getShowcaseApplication(product);
          const quoteHref = buildWhatsAppQuoteUrl({
            productName: product.name,
            brandName,
          });
          const gridPosition =
            index === 3
              ? 'lg:col-span-2 lg:col-start-2'
              : index === 4
                ? 'lg:col-span-2 lg:col-start-4'
                : 'lg:col-span-2';

          return (
            <li class:list={['flex', gridPosition]}>
              <article class="showcase-product-card group flex h-full w-full flex-col">
                {product.imagePath && (
                  <a
                    href={href}
                    class="showcase-product-image-link block rounded-t-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2"
                    tabindex={href ? undefined : -1}
                  >
                    <div class="flex h-40 items-center justify-center bg-white p-4 sm:h-44">
                      <img
                        src={product.imagePath}
                        alt={product.imageAlt ?? product.name}
                        loading="lazy"
                        width="320"
                        height="176"
                        class="max-h-full max-w-full object-contain"
                      />
                    </div>
                  </a>
                )}
                <div class="flex flex-1 flex-col p-5">
                  {product.equipmentType && (
                    <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">
                      {product.equipmentType}
                    </p>
                  )}
                  <h3 class="mt-1 text-lg font-bold text-brand-950">
                    {href ? (
                      <a
                        href={href}
                        class="rounded hover:text-brand-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2"
                      >
                        {product.name}
                      </a>
                    ) : (
                      product.name
                    )}
                  </h3>
                  <ul class="mt-3 flex flex-wrap gap-1.5" aria-label="Especificaciones destacadas">
                    <li class="showcase-spec-chip">{chips.rpm}</li>
                    <li class="showcase-spec-chip">{chips.capacity}</li>
                    <li class="showcase-spec-chip">{chips.cooling}</li>
                  </ul>
                  <p class="mt-3 text-sm leading-relaxed text-slate-600">{applicationLine}</p>
                  <div class="mt-auto flex flex-col gap-2 pt-5 sm:flex-row">
                    {href && (
                      <a href={href} class="btn-outline-dark flex-1 text-center text-sm">
                        {ctaLabels.viewProductDetail}
                      </a>
                    )}
                    <a
                      href={quoteHref}
                      class="btn-whatsapp flex-1 text-center text-sm"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {ctaLabels.whatsapp}
                    </a>
                  </div>
                </div>
              </article>
            </li>
          );
        })
      }
    </ul>

    {
      showComparison && comparisonRows.length > 0 && (
        <div class="mt-10">
          <h3 class="text-sm font-bold uppercase tracking-wide text-slate-500">
            Comparación rápida
          </h3>
          <p class="mt-1 text-xs text-slate-500">
            Referencia orientativa según documentación del fabricante; la configuración final se
            confirma en cotización.
          </p>

          <div class="showcase-comparison-table mt-4 hidden overflow-hidden rounded-xl border border-slate-200/80 bg-white md:block">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-slate-100 bg-slate-50/80 text-xs font-semibold uppercase tracking-wide text-slate-500">
                  <th scope="col" class="px-4 py-3">Modelo</th>
                  <th scope="col" class="px-4 py-3">Tipo</th>
                  <th scope="col" class="px-4 py-3">Capacidad máx.</th>
                  <th scope="col" class="px-4 py-3">Velocidad máx.</th>
                  <th scope="col" class="px-4 py-3">Temperatura</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {comparisonRows.map((row) => (
                  <tr class="text-slate-700">
                    <th scope="row" class="px-4 py-3 font-semibold text-brand-950">
                      {row.model}
                    </th>
                    <td class="px-4 py-3">{row.tipo}</td>
                    <td class="px-4 py-3">{row.capacity}</td>
                    <td class="px-4 py-3">{row.speed}</td>
                    <td class="px-4 py-3">{row.temperature}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <ul class="mt-4 space-y-3 md:hidden">
            {comparisonRows.map((row) => (
              <li class="rounded-xl border border-slate-200/80 bg-white p-4 text-sm">
                <p class="font-semibold text-brand-950">{row.model}</p>
                <dl class="mt-2 grid grid-cols-1 gap-2">
                  <div class="flex justify-between gap-3 border-b border-slate-50 pb-2">
                    <dt class="text-slate-500">Tipo</dt>
                    <dd class="text-right font-medium text-slate-800">{row.tipo}</dd>
                  </div>
                  <div class="flex justify-between gap-3 border-b border-slate-50 pb-2">
                    <dt class="text-slate-500">Capacidad máx.</dt>
                    <dd class="text-right font-medium text-slate-800">{row.capacity}</dd>
                  </div>
                  <div class="flex justify-between gap-3 border-b border-slate-50 pb-2">
                    <dt class="text-slate-500">Velocidad máx.</dt>
                    <dd class="text-right font-medium text-slate-800">{row.speed}</dd>
                  </div>
                  <div class="flex justify-between gap-3">
                    <dt class="text-slate-500">Temperatura</dt>
                    <dd class="text-right font-medium text-slate-800">{row.temperature}</dd>
                  </div>
                </dl>
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <p class="mt-8 text-xs leading-relaxed text-slate-500">{configurationNote}</p>
  </div>
</section>
