---
import type { Product } from '../data/products';
import { productPageHref } from '../lib/catalog';
import { buildWhatsAppQuoteUrl } from '../lib/whatsapp';
import { ctaLabels } from '../lib/ctaLabels';

interface Props {
  product: Product;
  brandName?: string;
  brandNameForQuote?: string;
  showBrand?: boolean;
  showApplication?: boolean;
  showCommercialNote?: boolean;
  showImage?: boolean;
  showWhatsApp?: boolean;
  class?: string;
}

const {
  product,
  brandName,
  brandNameForQuote,
  showBrand = false,
  showApplication = false,
  showCommercialNote = false,
  showImage = false,
  showWhatsApp = false,
  class: className = '',
} = Astro.props;

const href = productPageHref(product);
const whatsappHref = buildWhatsAppQuoteUrl({
  productName: product.name,
  brandName: brandNameForQuote ?? brandName,
});
const cardClass = `card-elevated flex h-full flex-col border-l-4 border-l-brand-500 ${className}`;
---

<article class={cardClass}>
  {showImage && product.imagePath && (
    <div class="mb-4 flex h-36 items-center justify-center rounded-lg bg-slate-50 p-3">
      <img
        src={product.imagePath}
        alt={product.imageAlt ?? product.name}
        loading="lazy"
        class="max-h-full max-w-full object-contain"
      />
    </div>
  )}
  {showBrand && brandName && (
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-700">{brandName}</p>
  )}
  {product.equipmentType && (
    <p class={`text-xs font-medium text-slate-500 ${showBrand && brandName ? 'mt-1' : ''}`}>
      {product.equipmentType}
    </p>
  )}
  <h3 class={`${showBrand && brandName ? 'mt-2 ' : product.equipmentType ? 'mt-1 ' : ''}font-semibold text-brand-950`}>
    {href ? (
      <a href={href} class="hover:text-brand-800">
        {product.name}
      </a>
    ) : (
      product.name
    )}
  </h3>
  <p class="mt-1 text-xs font-medium uppercase tracking-wide text-slate-500">
    {product.sku ? `Ítem ${product.sku}` : product.availabilityNote ?? 'Disponible bajo cotización'}
  </p>
  <p class="mt-2 text-sm leading-relaxed text-slate-600">{product.summary}</p>
  {showApplication && <p class="mt-2 text-sm text-slate-600">{product.application}</p>}
  {showCommercialNote && <p class="mt-3 text-xs leading-relaxed text-slate-500">{product.commercialNote}</p>}
  <div class="mt-auto flex flex-col gap-2 pt-4">
    {href && (
      <a href={href} class="text-sm font-semibold text-brand-700 hover:text-brand-800">
        {ctaLabels.viewProductDetail}
      </a>
    )}
    {showWhatsApp && (
      <a
        href={whatsappHref}
        class="btn-whatsapp text-center text-sm"
        target="_blank"
        rel="noopener noreferrer"
      >
        {ctaLabels.whatsapp}
      </a>
    )}
  </div>
</article>
