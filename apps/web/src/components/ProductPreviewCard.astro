---
import type { Product } from '../data/products';

interface Props {
  product: Product;
  brandName?: string;
  showBrand?: boolean;
  showApplication?: boolean;
  showCommercialNote?: boolean;
  class?: string;
}

const {
  product,
  brandName,
  showBrand = false,
  showApplication = false,
  showCommercialNote = false,
  class: className = '',
} = Astro.props;
---

<article class={`card-elevated h-full border-l-4 border-l-brand-500 ${className}`}>
  {showBrand && brandName && (
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-700">{brandName}</p>
  )}
  <h3 class={`${showBrand && brandName ? 'mt-2 ' : ''}font-semibold text-brand-950`}>{product.name}</h3>
  <p class="mt-1 text-xs font-medium uppercase tracking-wide text-slate-500">
    {product.sku ? `Ítem ${product.sku}` : 'Referencia por confirmar'}
  </p>
  <p class="mt-2 text-sm leading-relaxed text-slate-600">{product.summary}</p>
  {showApplication && <p class="mt-2 text-sm text-slate-600">{product.application}</p>}
  {showCommercialNote && <p class="mt-3 text-xs leading-relaxed text-slate-500">{product.commercialNote}</p>}
</article>
