---
import { getBrandById, getOrtoalresaCentrifuges, getProductsByBrandId } from '../lib/catalog';
import { buildWhatsAppQuoteUrl } from '../lib/whatsapp';
import { ctaLabels } from '../lib/ctaLabels';
import HomeProductImagePreview from './HomeProductImagePreview.astro';

const servaBrand = getBrandById('serva');
const servaBrandName = servaBrand?.homeCardTitle ?? 'SERVA Electrophoresis';
const servaBrandHref = servaBrand ? `/marcas/${servaBrand.slug}` : '/marcas/serva-electrophoresis';
const servaProducts = servaBrand
  ? getProductsByBrandId(servaBrand.id).filter((p) => p.showOnBrandPage).slice(0, 3)
  : [];

const servaSkuMeta: Record<string, { eyebrow: string; shortName: string }> = {
  'blueslick-42500': { eyebrow: 'Reactivo', shortName: 'BlueSlick™' },
  'temed-25ml': { eyebrow: 'Reactivo', shortName: 'TEMED 25 ml' },
  'repel-silane-ge17-1332-01': { eyebrow: 'Insumo', shortName: 'REPEL-SILANE' },
};

const ortoalresaCentrifuges = getOrtoalresaCentrifuges();
const ortoalresaQuoteHref = buildWhatsAppQuoteUrl({ brandName: 'Ortoalresa' });
const servaQuoteHref = buildWhatsAppQuoteUrl({ brandName: servaBrandName });

const lineCardClass =
  'home-line-card flex w-full flex-col rounded-2xl border border-slate-200/70 bg-gradient-to-b from-white to-slate-50/60 p-5 shadow-md sm:p-6';
const ctaRowClass = 'mt-5 flex flex-col gap-2 sm:flex-row';
---

<section class="home-section" aria-labelledby="home-commercial-lines-heading">
  <header class="max-w-3xl">
    <h2 id="home-commercial-lines-heading" class="text-2xl font-bold tracking-tight text-brand-950 md:text-3xl">
      Líneas disponibles para cotización
    </h2>
    <p class="mt-3 text-base leading-relaxed text-slate-600">
      Equipos, reactivos e insumos seleccionados para laboratorios de servicio, investigación, control de
      calidad y laboratorio clínico.
    </p>
  </header>

  <ul class="mt-10 grid gap-6 lg:grid-cols-2 lg:items-start">
    <li>
      <article class={lineCardClass}>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-700">Ortoalresa</p>
        <h3 class="mt-1.5 text-xl font-bold text-brand-950">Centrífugas Ortoalresa</h3>
        <p class="mt-2 text-sm leading-relaxed text-slate-600">
          Microcentrífugas, centrífugas universales y modelos refrigerados para preparación de muestras,
          control de calidad e investigación.
        </p>
        {ortoalresaCentrifuges.length > 0 && (
          <HomeProductImagePreview products={ortoalresaCentrifuges} />
        )}
        <div class={ctaRowClass}>
          <a href="/productos/centrifugas" class="btn-outline-dark flex-1 text-center text-sm">
            Ver centrífugas
          </a>
          <a
            href={ortoalresaQuoteHref}
            class="btn-whatsapp flex-1 text-center text-sm"
            target="_blank"
            rel="noopener noreferrer"
          >
            {ctaLabels.quoteLine}
          </a>
        </div>
      </article>
    </li>

    <li>
      <article class={lineCardClass}>
        <div class="flex flex-wrap items-center gap-4">
          <div class="min-w-0 flex-1">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-700">
              SERVA Electrophoresis
            </p>
            <h3 class="mt-1.5 text-xl font-bold text-brand-950">Reactivos e insumos SERVA</h3>
          </div>
          {
            servaBrand?.logoPath && (
              <div class="shrink-0 rounded-xl border border-slate-200/80 bg-white px-4 py-3">
                <img
                  src={servaBrand.logoPath}
                  alt={servaBrand.logoAlt ?? 'Logo SERVA Electrophoresis'}
                  width="140"
                  height="48"
                  class="h-10 w-auto max-w-[8.5rem] object-contain"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            )
          }
        </div>
        <p class="mt-2 text-sm leading-relaxed text-slate-600">
          Reactivos e insumos para flujos de electroforesis y preparación de muestras, disponibles bajo
          cotización y confirmación comercial.
        </p>
        {servaProducts.length > 0 && (
          <ul class="mt-4 grid gap-2 sm:grid-cols-3" aria-label="Referencias SERVA">
            {servaProducts.map((product) => {
              const meta = servaSkuMeta[product.slug] ?? {
                eyebrow: 'Referencia',
                shortName: product.name,
              };
              const quoteHref = buildWhatsAppQuoteUrl({
                productName: product.name,
                brandName: servaBrandName,
              });
              return (
                <li>
                  <a
                    href={quoteHref}
                    class="flex h-full min-h-[4.75rem] flex-col justify-center rounded-xl border border-slate-200/90 bg-white px-3 py-2.5 transition hover:-translate-y-0.5 hover:border-brand-300 hover:bg-brand-50 hover:shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Cotizar ${product.name}, ${meta.eyebrow}`}
                  >
                    <span class="text-[0.65rem] font-semibold uppercase tracking-wide text-brand-700">
                      {meta.eyebrow}
                    </span>
                    <span class="mt-1 block text-sm font-semibold leading-snug text-brand-950">
                      {meta.shortName}
                    </span>
                  </a>
                </li>
              );
            })}
          </ul>
        )}
        <div class={ctaRowClass}>
          <a href={servaBrandHref} class="btn-outline-dark flex-1 text-center text-sm">
            Ver línea SERVA
          </a>
          <a
            href={servaQuoteHref}
            class="btn-whatsapp flex-1 text-center text-sm"
            target="_blank"
            rel="noopener noreferrer"
          >
            {ctaLabels.quoteLine}
          </a>
        </div>
      </article>
    </li>
  </ul>
</section>
