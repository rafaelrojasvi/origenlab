---
import { buildQuoteMailtoUrl, buildWhatsAppQuoteUrl } from '../lib/whatsapp';
import { ctaLabels } from '../lib/ctaLabels';

interface Props {
  productName?: string;
  brandName?: string;
  class?: string;
  compact?: boolean;
}

const { productName, brandName, class: className = '', compact = false } = Astro.props;

const whatsappHref = buildWhatsAppQuoteUrl({ productName, brandName });
const mailtoHref = buildQuoteMailtoUrl({ productName, brandName });
---

<div class={`flex flex-col gap-3 ${compact ? '' : 'sm:flex-row sm:flex-wrap'} ${className}`}>
  <a
    href={whatsappHref}
    class="btn-whatsapp text-center"
    target="_blank"
    rel="noopener noreferrer"
    aria-label={ctaLabels.whatsapp}
  >
    {ctaLabels.whatsapp}
  </a>
  <a href={mailtoHref} class="btn-outline-dark text-center" aria-label={ctaLabels.email}>
    {ctaLabels.email}
  </a>
</div>
