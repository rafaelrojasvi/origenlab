---
import type { Brand } from '../data/brands';

interface Props {
  brands: Brand[];
}

const { brands } = Astro.props;
---

<section class="py-12" aria-labelledby="home-brands-heading">
  <div>
    <h2 id="home-brands-heading" class="section-title">Marcas y líneas disponibles</h2>
    <p class="mt-2 max-w-3xl text-sm leading-relaxed text-slate-600">
      Equipos, reactivos e insumos seleccionados para laboratorios de servicio, investigación, control de
      calidad y laboratorio clínico. Cotización y disponibilidad sujetas a confirmación comercial.
    </p>
  </div>

  <ul class="mt-8 grid gap-4 sm:grid-cols-2">
    {brands.map((brand) => (
      <li class="card-elevated flex h-full flex-col border border-brand-100">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h3 class="font-semibold text-brand-950">{brand.homeCardTitle ?? brand.name}</h3>
          </div>
          {brand.logoPath && (
            <img
              src={brand.logoPath}
              alt={brand.logoAlt ?? brand.name}
              loading="lazy"
              class="h-10 w-auto shrink-0 object-contain md:h-12"
            />
          )}
        </div>
        <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-600">
          {brand.homeCardDescription ?? brand.summary}
        </p>
        <div class="mt-5 flex flex-col gap-2 sm:flex-row">
          <a href={`/marcas/${brand.slug}`} class="btn-outline-dark text-center">
            {brand.homeCardCtaLabel ?? `Ver ${brand.name}`}
          </a>
          <a href="/contacto" class="btn-primary text-center text-sm">Solicitar cotización</a>
        </div>
      </li>
    ))}
  </ul>
</section>
