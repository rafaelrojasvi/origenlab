---
import OrigenLogoMarkStatic from './OrigenLogoMarkStatic.astro';
import { lockupMarkPx } from '../../lib/logo/composition';
import { tokensForVariant, type LogoVariant } from '../../lib/logo/variants';
import type { MarkSolution } from '../../lib/logo/markGeometry';

interface Props {
  variant?: LogoVariant;
  size?: 'sm' | 'md' | 'lg';
  solution?: MarkSolution;
  showRings?: boolean;
  gap?: 'tight' | 'normal';
  transparentBg?: boolean;
  class?: string;
}

const {
  variant = 'dark',
  size = 'md',
  solution = 'premium',
  showRings = true,
  gap = 'normal',
  transparentBg = false,
  class: className = '',
} = Astro.props;

const tokens = tokensForVariant(variant);
const markSize = lockupMarkPx(size);
const gapClass = gap === 'tight' ? 'gap-1.5' : 'gap-2.5';
const markTightClass = gap === 'tight' ? '-mr-1' : '';
const textClass =
  size === 'sm'
    ? 'text-[0.9375rem] font-bold tracking-tight leading-none'
    : gap === 'tight' && size === 'md'
      ? 'text-xl font-bold tracking-tight leading-none lg:text-2xl'
      : size === 'lg'
        ? 'text-xl font-bold tracking-tight leading-none'
        : 'text-xl font-bold tracking-tight leading-none';
---

<span class:list={['inline-flex items-center', gapClass, className]}>
  <OrigenLogoMarkStatic
    size={markSize}
    variant={variant}
    solution={solution}
    showRings={showRings}
    transparentBg={transparentBg}
    class={markTightClass}
  />
  <span class:list={[textClass]} style={`color: ${tokens.wordmark}`}>OrigenLab</span>
</span>
