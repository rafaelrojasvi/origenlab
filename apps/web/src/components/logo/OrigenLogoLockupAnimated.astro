---
import OrigenThreeBodyCanvas from './OrigenThreeBodyCanvas.astro';
import OrigenLogoLockup from './OrigenLogoLockup.astro';
import {
  HEADER_CANVAS_PX,
  HEADER_DISPLAY_PX,
  lockupMarkPx,
} from '../../lib/logo/composition';
import { getMotionPreset, type MotionContext } from '../../lib/logo/motionPresets';
import type { LogoVariant } from '../../lib/logo/variants';
import type { MarkSolution } from '../../lib/logo/markGeometry';

interface Props {
  variant?: LogoVariant;
  size?: 'sm' | 'md' | 'lg';
  solution?: MarkSolution;
  showRings?: boolean;
  motion?: MotionContext;
  /** Tighter icon–wordmark spacing (header). */
  gap?: 'tight' | 'normal';
  /** Parent link provides accessible name (e.g. site header). */
  decorative?: boolean;
  class?: string;
}

const {
  variant = 'dark',
  size = 'md',
  solution = 'premium',
  showRings = true,
  motion = 'header',
  gap = 'normal',
  decorative = false,
  class: className = '',
} = Astro.props;

const preset = getMotionPreset(motion);

const markDisplay = lockupMarkPx(size);
const isHeader = motion === 'header';
const canvasPx = isHeader ? HEADER_CANVAS_PX : markDisplay;
const displayPx = isHeader ? HEADER_DISPLAY_PX : markDisplay;

const gapClass = gap === 'tight' ? 'gap-1.5' : 'gap-2.5';
const canvasTightClass = gap === 'tight' ? '-mr-1' : '';

const textClass =
  size === 'sm'
    ? 'text-[0.9375rem] font-bold tracking-tight leading-none'
    : gap === 'tight' && size === 'md'
      ? 'text-xl font-bold tracking-tight leading-none lg:text-2xl'
      : size === 'lg'
        ? 'text-xl font-bold tracking-tight leading-none'
        : 'text-xl font-bold tracking-tight leading-none';
---

<span
  class:list={['inline-flex items-center', gapClass, 'motion-reduce:hidden', className]}
  role={decorative ? undefined : 'img'}
  aria-label={decorative ? undefined : 'OrigenLab'}
  aria-hidden={decorative ? true : undefined}
>
  <OrigenThreeBodyCanvas
    canvasSize={canvasPx}
    displaySize={displayPx}
    variant={variant}
    solution={solution}
    showRings={showRings}
    loopSeconds={preset.loopSeconds}
    trailLength={preset.trailLength}
    motionContext={motion}
    class:list={['shrink-0', canvasTightClass]}
  />
  <span class:list={[textClass, 'shrink-0 text-brand-50']}>OrigenLab</span>
</span>

<span
  class:list={['hidden motion-reduce:inline-flex', className]}
  role={decorative ? undefined : 'img'}
  aria-label={decorative ? undefined : 'OrigenLab'}
  aria-hidden={decorative ? true : undefined}
>
  <OrigenLogoLockup
    variant={variant}
    size={size}
    solution={solution}
    showRings={showRings}
    gap={gap}
    transparentBg={isHeader}
  />
</span>
