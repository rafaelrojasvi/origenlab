---
/**
 * Animated hero mark — real three-body simulation in canvas (canvasAnimator.ts).
 * `canvasSize` can exceed `displaySize` for extra safe margin (header lockup).
 */
import OrigenLogoMarkStatic from './OrigenLogoMarkStatic.astro';
import { trailStyleForSolution } from '../../lib/logo/variants';
import type { MarkSolution } from '../../lib/logo/markGeometry';
import type { LogoVariant } from '../../lib/logo/variants';
import type { MotionContext } from '../../lib/logo/motionPresets';

interface Props {
  /** CSS box size (px). Defaults to canvasSize. */
  size?: number;
  /** Canvas pixel buffer (defaults to size). Use larger value + smaller displaySize for padding. */
  canvasSize?: number;
  displaySize?: number;
  loopSeconds?: number;
  trailLength?: number;
  showWordmark?: boolean;
  showRings?: boolean;
  solution?: MarkSolution;
  variant?: LogoVariant;
  motionContext?: MotionContext;
  class?: string;
}

const {
  size,
  canvasSize,
  displaySize,
  loopSeconds = 14,
  trailLength,
  showWordmark = false,
  showRings = true,
  solution = 'premium',
  variant = 'dark',
  motionContext,
  class: className = '',
} = Astro.props;

const trail = trailStyleForSolution(solution);
const resolvedTrail = trailLength ?? trail.tailLength;
const bufferPx = canvasSize ?? size ?? 320;
const boxPx = displaySize ?? size ?? bufferPx;
const staticPx = boxPx;
const canvasId = `origen-canvas-${Math.random().toString(36).slice(2, 9)}`;
const transparentBg = motionContext === 'header';
---

<div
  class:list={['relative inline-flex shrink-0 items-center justify-center', className]}
  style={`width: ${boxPx}px; height: ${boxPx}px;`}
>
  <canvas
    id={canvasId}
    data-origen-three-body
    data-loop-seconds={loopSeconds}
    data-trail-length={resolvedTrail}
    data-show-rings={showRings ? 'true' : 'false'}
    data-show-wordmark={showWordmark ? 'true' : 'false'}
    data-solution={solution}
    data-variant={variant}
    data-motion-context={motionContext}
    class="motion-reduce:hidden"
    style={`width: ${boxPx}px; height: ${boxPx}px;`}
    width={bufferPx}
    height={bufferPx}
    aria-hidden={showWordmark ? undefined : true}
    role={showWordmark ? 'img' : undefined}
    aria-label={showWordmark ? 'OrigenLab animated mark' : undefined}
  ></canvas>

  <div class="absolute inset-0 hidden items-center justify-center motion-reduce:flex" aria-hidden={!showWordmark}>
    <OrigenLogoMarkStatic
      size={staticPx}
      variant={variant}
      solution={solution}
      showRings={showRings}
      transparentBg={transparentBg}
    />
  </div>

  <noscript>
    <OrigenLogoMarkStatic
      size={staticPx}
      variant={variant}
      solution={solution}
      showRings={showRings}
      transparentBg={transparentBg}
    />
  </noscript>
</div>

<script>
  import { initThreeBodyCanvases } from '../../lib/logo/canvasAnimator';

  initThreeBodyCanvases();
</script>
