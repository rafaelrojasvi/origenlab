---
/** Dev-only layout helper for `/logo-lab` — compares the three mark directions. */
import OrigenLogoMarkStatic from './OrigenLogoMarkStatic.astro';
import OrigenLogoLockupAnimated from './OrigenLogoLockupAnimated.astro';
import OrigenThreeBodyCanvas from './OrigenThreeBodyCanvas.astro';
import { getMotionPreset } from '../../lib/logo/motionPresets';
import { MARK_NOTES, type MarkSolution } from '../../lib/logo/markGeometry';

const solutions: MarkSolution[] = ['premium', 'trace', 'minimal'];
const heroMotion = getMotionPreset('hero');

const tradeoffs: Record<MarkSolution, string> = {
  premium: 'Strongest atom identity; may crowd 16px favicon.',
  trace: 'Most motion-forward; less iconic as a tiny square.',
  minimal: 'Sharpest at 16px; too simple for main header.',
};
---

<section class="space-y-16">
  <article class="overflow-hidden rounded-2xl border border-brand-800/40 bg-brand-950 shadow-lg">
    <header class="border-b border-brand-800/50 px-6 py-5">
      <h2 class="text-xl font-bold text-brand-50">Animated hero</h2>
      <p class="mt-1 text-sm text-brand-200/90">Strongest motion — {heroMotion.label}.</p>
      <p class="mt-2 text-sm font-semibold text-brand-300">Recommended for home hero · {heroMotion.loopSeconds}s loop</p>
      <p class="mt-1 text-xs text-brand-400/90">Tradeoff: {tradeoffs.premium} Needs JS; static fallback for reduced motion.</p>
    </header>
    <div class="flex flex-col items-center gap-6 px-6 py-10 sm:flex-row sm:justify-center">
      <OrigenThreeBodyCanvas
        size={260}
        solution="premium"
        loopSeconds={heroMotion.loopSeconds}
        trailLength={heroMotion.trailLength}
        showRings={true}
      />
      <OrigenThreeBodyCanvas
        size={260}
        solution="premium"
        loopSeconds={heroMotion.loopSeconds}
        trailLength={heroMotion.trailLength}
        showWordmark={true}
        showRings={true}
        class="hidden sm:block"
      />
    </div>
  </article>

  <div class="grid gap-6 lg:grid-cols-3">
    <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <h3 class="text-xs font-bold uppercase tracking-wider text-slate-500">Header lockup (animated)</h3>
      <div class="mt-4 flex min-h-[4rem] items-center justify-center rounded-lg bg-brand-950 py-6">
        <OrigenLogoLockupAnimated variant="dark" size="md" solution="premium" motion="header" gap="tight" />
      </div>
      <p class="mt-3 text-xs text-slate-600">36px icon · 44px canvas · {getMotionPreset('header').label}</p>
    </article>
    <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <h3 class="text-xs font-bold uppercase tracking-wider text-slate-500">Footer / dark (animated)</h3>
      <div class="mt-4 flex min-h-[4rem] items-center justify-center rounded-lg bg-brand-950 py-6">
        <OrigenLogoLockupAnimated variant="dark" size="md" solution="premium" motion="footer" />
      </div>
      <p class="mt-3 text-xs text-slate-600">md · 36px icon · {getMotionPreset('footer').label}</p>
    </article>
    <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <h3 class="text-xs font-bold uppercase tracking-wider text-slate-500">White card (animated)</h3>
      <div class="mt-4 flex min-h-[4rem] items-center justify-center rounded-lg border border-slate-100 bg-white py-6">
        <OrigenLogoLockupAnimated variant="light" size="md" solution="premium" motion="surface" />
      </div>
      <p class="mt-3 text-xs text-slate-600">md · 36px icon · {getMotionPreset('surface').label}</p>
    </article>
  </div>

  <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
    <h3 class="text-xs font-bold uppercase tracking-wider text-slate-500">Favicon scale</h3>
    <div class="mt-4 flex flex-wrap items-center gap-6">
      <OrigenLogoMarkStatic size={16} variant="dark" solution="minimal" showRings={false} />
      <OrigenLogoMarkStatic size={24} variant="dark" solution="minimal" showRings={false} />
      <OrigenLogoMarkStatic size={32} variant="dark" solution="minimal" showRings={false} />
      <span class="text-xs text-slate-500">16 / 24 / 32px static — minimal solution</span>
    </div>
    <p class="mt-3 text-xs text-slate-600">Tradeoff: {tradeoffs.minimal}. Favicon stays static in production.</p>
  </article>

  {
    solutions.map((solution) => {
      const notes = MARK_NOTES[solution];
      return (
        <article class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
          <header class="border-b border-slate-100 bg-slate-50 px-6 py-5">
            <h2 class="text-xl font-bold text-brand-950">{notes.title}</h2>
            <p class="mt-2 inline-block rounded-full bg-brand-100 px-3 py-1 text-xs font-bold text-brand-800">
              {notes.recommended}
            </p>
            <p class="mt-2 text-sm text-slate-600">{notes.description}</p>
            <p class="mt-2 text-sm font-semibold text-brand-700">Also: {notes.bestFor}</p>
            <p class="mt-1 text-xs text-slate-500">Tradeoff: {tradeoffs[solution]}</p>
          </header>

          <div class="grid gap-6 p-6 lg:grid-cols-2">
            <div class="space-y-4">
              <h3 class="text-xs font-bold uppercase tracking-wider text-slate-500">Dark header (animated)</h3>
              <div class="flex min-h-[5.5rem] items-center justify-center rounded-xl bg-brand-950 px-6 py-8">
                <OrigenLogoLockupAnimated
                  variant="dark"
                  size="md"
                  solution={solution}
                  motion="header"
                  showRings={solution !== 'minimal'}
                />
              </div>
            </div>

            <div class="space-y-4">
              <h3 class="text-xs font-bold uppercase tracking-wider text-slate-500">White card (animated)</h3>
              <div class="flex min-h-[5.5rem] items-center justify-center rounded-xl border border-slate-200 bg-white px-6 py-8">
                <OrigenLogoLockupAnimated
                  variant="light"
                  size="md"
                  solution={solution}
                  motion="surface"
                  showRings={solution !== 'minimal'}
                />
              </div>
            </div>

            <div class="space-y-4">
              <h3 class="text-xs font-bold uppercase tracking-wider text-slate-500">Static sizes (32 / 48 / 96)</h3>
              <div class="flex flex-wrap items-end gap-6 rounded-xl border border-slate-200 bg-slate-50 px-6 py-6">
                <OrigenLogoMarkStatic size={32} variant="dark" solution={solution} />
                <OrigenLogoMarkStatic size={48} variant="dark" solution={solution} />
                <OrigenLogoMarkStatic size={96} variant="dark" solution={solution} />
              </div>
              <p class="text-xs text-slate-500">Static reference for export / print</p>
            </div>

            <div class="space-y-4">
              <h3 class="text-xs font-bold uppercase tracking-wider text-slate-500">Favicon scale (16px static)</h3>
              <div class="flex items-center gap-4 rounded-xl border border-slate-200 bg-brand-950 px-6 py-6">
                <OrigenLogoMarkStatic size={16} variant="dark" solution={solution} showRings={solution !== 'trace'} />
                <span class="text-xs text-brand-200">Browser tab — static only</span>
              </div>
            </div>

            <div class="space-y-4 lg:col-span-2">
              <h3 class="text-xs font-bold uppercase tracking-wider text-slate-500">Hero animation</h3>
              <div class="flex flex-col items-center gap-6 rounded-xl bg-brand-950 px-6 py-10 sm:flex-row sm:justify-center">
                <OrigenThreeBodyCanvas
                  size={280}
                  solution={solution}
                  variant="dark"
                  loopSeconds={heroMotion.loopSeconds}
                  trailLength={heroMotion.trailLength}
                  showRings={solution !== 'minimal'}
                />
                {solution === 'premium' && (
                  <OrigenThreeBodyCanvas
                    size={280}
                    solution="premium"
                    variant="dark"
                    loopSeconds={heroMotion.loopSeconds}
                    trailLength={heroMotion.trailLength}
                    showWordmark={true}
                    showRings={true}
                    class="hidden md:block"
                  />
                )}
              </div>
              <p class="text-center text-xs text-slate-500">
                Strongest motion tier. Pauses off-screen. Respects{' '}
                <code class="rounded bg-slate-100 px-1">prefers-reduced-motion</code>.
              </p>
            </div>
          </div>
        </article>
      );
    })
  }
</section>
