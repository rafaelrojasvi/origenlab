---
import { getMarkGeometry, type MarkSolution } from '../../lib/logo/markGeometry';
import { LOGO_PALETTE } from '../../lib/logo/palette';
import { SVG_RING_SCALE, SVG_VIEW_HALF } from '../../lib/logo/composition';
import { ringOpacityForSolution, tokensForVariant, type LogoVariant } from '../../lib/logo/variants';

interface Props {
  size?: number;
  variant?: LogoVariant;
  solution?: MarkSolution;
  showRings?: boolean;
  /** Omit background rect (header / transparent surfaces) */
  transparentBg?: boolean;
  /** Lighter rings/electrons on dark backgrounds (favicon previews) */
  brightAtom?: boolean;
  class?: string;
  title?: string;
}

const {
  size = 48,
  variant = 'dark',
  solution = 'premium',
  showRings = true,
  transparentBg = false,
  brightAtom = false,
  class: className = '',
  title = 'OrigenLab',
} = Astro.props;

const tokens = tokensForVariant(variant);
const ringStroke = brightAtom && variant === 'dark' ? LOGO_PALETTE.brand200 : tokens.ring;
const ringAlpha = brightAtom ? Math.min(ringOpacityForSolution(solution) + 0.14, 0.62) : ringOpacityForSolution(solution);
const geo = getMarkGeometry(solution);
const rings = showRings ? geo.ringSpecs : [];
const isPremium = solution === 'premium';
const isMinimal = solution === 'minimal';

const coreColors = brightAtom
  ? ([LOGO_PALETTE.brand50, LOGO_PALETTE.brand100, LOGO_PALETTE.brand200] as const)
  : ([LOGO_PALETTE.brand100, LOGO_PALETTE.brand200, LOGO_PALETTE.brand300] as const);
const glowColors = brightAtom
  ? ([LOGO_PALETTE.brand200, LOGO_PALETTE.brand300, LOGO_PALETTE.brand400] as const)
  : ([LOGO_PALETTE.brand300, LOGO_PALETTE.brand400, LOGO_PALETTE.brand500] as const);
const nucleusFill = brightAtom && variant === 'dark' ? LOGO_PALETTE.brand50 : tokens.nucleus;
const nucleusRingStroke = brightAtom && variant === 'dark' ? LOGO_PALETTE.brand100 : tokens.nucleusRing;

const ringScale = isPremium ? SVG_RING_SCALE : 0.72;
const viewHalf = SVG_VIEW_HALF;
const bgRadius = brightAtom ? viewHalf * 0.32 : 0;
const ringWidth = isPremium ? 0.09 : solution === 'trace' ? 0.075 : 0.065;
const accentWidth = isPremium ? 0.11 : solution === 'trace' ? 0.14 : 0.1;
const accentOpacity = isPremium ? 0.75 : solution === 'trace' ? 0.92 : 0.75;
const bodyR = isMinimal ? 0.1 : isPremium ? 0.1 : 0.088;
const nucleusR = isPremium ? 0.22 : 0.18;
const nucleusRingR = isPremium ? 0.3 : 0.28;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox={`-${viewHalf} -${viewHalf} ${viewHalf * 2} ${viewHalf * 2}`}
  width={size}
  height={size}
  class:list={['shrink-0', className]}
  role="img"
  aria-label={title}
>
  <title>{title}</title>
  {!transparentBg && (
    <rect
      x={-viewHalf}
      y={-viewHalf}
      width={viewHalf * 2}
      height={viewHalf * 2}
      rx={bgRadius}
      ry={bgRadius}
      fill={tokens.bg}
    />
  )}

  {
    rings.map((ring) => (
      <ellipse
        cx="0"
        cy="0"
        rx={ring.rx * ringScale}
        ry={ring.ry * ringScale}
        transform={`rotate(${ring.angle})`}
        fill="none"
        stroke={ringStroke}
        stroke-width={ringWidth}
        opacity={ringAlpha}
      />
    ))
  }

  {
    !isPremium &&
      geo.bodyPaths.map((d, i) => (
        <path
          d={d}
          fill="none"
          stroke={coreColors[i]}
          stroke-width={accentWidth}
          stroke-linecap="round"
          stroke-linejoin="round"
          opacity={accentOpacity - i * 0.06}
        />
      ))
  }

  {
    isPremium &&
      geo.bodyPaths.map((d, i) => (
        <path
          d={d}
          fill="none"
          stroke={glowColors[i]}
          stroke-width={accentWidth}
          stroke-linecap="round"
          stroke-linejoin="round"
          opacity={0.5}
        />
      ))
  }

  <circle
    cx="0"
    cy="0"
    r={nucleusRingR}
    fill="none"
    stroke={nucleusRingStroke}
    stroke-width="0.055"
    opacity={brightAtom ? 0.4 : isPremium ? 0.28 : 0.22}
  />
  <circle cx="0" cy="0" r={nucleusR} fill={nucleusFill} />

  {
    geo.bodyPositions.map(([x, y], i) => (
      <g>
        {
          !isMinimal && (
            <circle cx={x} cy={y} r={bodyR * 1.9} fill={glowColors[i]} opacity={isPremium ? 0.32 : 0.28} />
          )
        }
        <circle cx={x} cy={y} r={bodyR} fill={coreColors[i]} />
      </g>
    ))
  }
</svg>
