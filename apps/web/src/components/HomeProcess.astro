---
const steps = [
  {
    number: '1',
    title: 'Cuéntenos su necesidad',
    text: 'Indique tipo de laboratorio, aplicación o equipo de interés.',
  },
  {
    number: '2',
    title: 'Revisamos alternativas',
    text: 'Evaluamos líneas y configuraciones según lo que podamos ofrecer en cada momento.',
  },
  {
    number: '3',
    title: 'Enviamos cotización',
    text: 'Propuesta comercial con disponibilidad y condiciones sujetas a confirmación.',
  },
  {
    number: '4',
    title: 'Coordinamos condiciones',
    text: 'Documentación, logística y soporte según acuerdo para cada línea.',
  },
] as const;

const supportNotes = [
  'Asesoría antes de comprar',
  'Garantía según fabricante',
  'Instalación o puesta en marcha solo cuando quede acordada por escrito',
  'Documentación técnica según línea disponible',
] as const;
---

<section class="home-section home-section-alt" aria-labelledby="home-process-heading">
  <header class="max-w-2xl">
    <h2 id="home-process-heading" class="text-2xl font-bold tracking-tight text-brand-950 md:text-3xl">
      Cómo trabajamos
    </h2>
    <p class="mt-3 text-slate-600">
      Proceso orientado a cotización y acompañamiento técnico-comercial, sin promesas que no estén
      confirmadas por escrito.
    </p>
  </header>

  <ol class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {
      steps.map((step) => (
        <li>
          <article class="home-process-step h-full">
            <span
              class="flex h-9 w-9 items-center justify-center rounded-full bg-brand-700 text-sm font-bold text-white"
              aria-hidden="true"
            >
              {step.number}
            </span>
            <h3 class="mt-3 font-bold text-brand-950">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{step.text}</p>
          </article>
        </li>
      ))
    }
  </ol>

  <ul class="mt-8 flex flex-wrap gap-2 border-t border-slate-200/80 pt-6" aria-label="Notas de soporte">
    {
      supportNotes.map((note) => (
        <li>
          <span class="rounded-lg bg-white/80 px-3 py-1.5 text-xs text-slate-600 shadow-sm">{note}</span>
        </li>
      ))
    }
  </ul>
</section>
