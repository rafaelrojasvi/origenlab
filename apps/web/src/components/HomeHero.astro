---
import { getBrandById, getProductBySlug, productPageHref } from '../lib/catalog';
import { HOME_HERO_FEATURED_SLUG, homePreviewTypeLabel } from '../lib/homeProductPreview';
import { buildWhatsAppQuoteUrl } from '../lib/whatsapp';
import { ctaLabels } from '../lib/ctaLabels';
import { site } from '../config/site';

const heroFeatured =
  getProductBySlug(HOME_HERO_FEATURED_SLUG) ??
  getProductBySlug('digicen-22-r') ??
  getProductBySlug('consul-22');
const heroThumb = getProductBySlug('digicen-22-r') ?? getProductBySlug('consul-22');
const heroFeaturedTypeLabel = heroFeatured ? homePreviewTypeLabel(heroFeatured) : '';
const servaBrand = getBrandById('serva');
const featuredHref = heroFeatured ? productPageHref(heroFeatured) : '/productos/centrifugas';
const whatsappHref = buildWhatsAppQuoteUrl();

const trustChips = [
  'Valdivia · atención nacional',
  'Cotización por correo o WhatsApp',
  'Asesoría antes de comprar',
  'Disponibilidad sujeta a confirmación',
] as const;

const categoryChips = [
  { label: 'Alimentos', href: '/categorias/alimentos' },
  { label: 'Control de calidad', href: '/categorias/control-de-calidad' },
  { label: 'Laboratorio clínico', href: '/categorias/laboratorio-clinico' },
] as const;
---

<section
  class="relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen overflow-hidden bg-gradient-to-br from-brand-950 via-brand-900 to-brand-800"
  aria-labelledby="home-hero-heading"
>
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.12]"
    style="background-image: radial-gradient(circle at 20% 20%, #5eead4 0%, transparent 45%), radial-gradient(circle at 80% 0%, #14b8a6 0%, transparent 40%);"
    aria-hidden="true"
  />
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.06]"
    style={`background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E");`}
    aria-hidden="true"
  />

  <div class="relative mx-auto grid max-w-7xl gap-10 px-5 py-12 md:grid-cols-2 md:items-center md:gap-12 md:py-16 lg:px-8 lg:py-20">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-200">{site.name}</p>
      <h1
        id="home-hero-heading"
        class="mt-3 text-3xl font-bold leading-[1.12] tracking-tight text-white sm:text-4xl lg:text-[2.65rem]"
      >
        Equipos para laboratorio, cotizados con criterio técnico
      </h1>
      <p class="mt-5 max-w-xl text-base leading-relaxed text-brand-100/95 md:text-lg">
        {site.name} acompaña a laboratorios de servicio, investigación, universidades, clínicas e industria
        en la evaluación y cotización de equipos e insumos para todo Chile.
      </p>

      <ul class="mt-6 flex flex-wrap gap-2" aria-label="Contexto comercial">
        {
          trustChips.map((chip) => (
            <li>
              <span class="home-chip border-white/25 bg-white/10 text-brand-50">{chip}</span>
            </li>
          ))
        }
      </ul>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <a href="/contacto" class="btn-primary-light text-center sm:min-w-[11rem]">
          {ctaLabels.solicitarCotizacion}
        </a>
        <a href="/productos" class="btn-outline text-center sm:min-w-[11rem]">Ver productos</a>
        <a
          href={whatsappHref}
          class="inline-flex items-center justify-center rounded-lg border border-emerald-400/40 bg-emerald-600/90 px-5 py-3 text-center text-sm font-semibold text-white transition hover:bg-emerald-600 sm:min-w-[11rem]"
          target="_blank"
          rel="noopener noreferrer"
        >
          {ctaLabels.whatsapp}
        </a>
      </div>
    </div>

    <div class="relative" aria-label="Vista previa de líneas y categorías">
      <div class="home-panel p-4 md:p-5">
        <div class="grid grid-cols-2 gap-3">
          {
            heroFeatured?.imagePath && (
              <a
                href={featuredHref}
                class="col-span-2 group block overflow-hidden rounded-xl border border-slate-200/80 bg-gradient-to-b from-slate-50 to-white p-4 transition hover:border-brand-300 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
              >
                <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Ortoalresa</p>
                <p class="mt-0.5 font-bold text-brand-950">{heroFeatured.name}</p>
                <div class="mt-3 flex min-h-[9rem] items-center justify-center sm:min-h-[11rem]">
                  <img
                    src={heroFeatured.imagePath}
                    alt={heroFeatured.imageAlt ?? `Centrífuga Ortoalresa ${heroFeatured.name}`}
                    width="320"
                    height="240"
                    class="max-h-44 w-auto object-contain transition group-hover:scale-[1.02] sm:max-h-52"
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                  />
                </div>
                <p class="mt-2 text-xs text-slate-500">{heroFeaturedTypeLabel}</p>
              </a>
            )
          }

          {
            heroThumb?.imagePath && heroThumb.slug !== heroFeatured?.slug && (
              <a
                href={productPageHref(heroThumb) ?? '/productos/centrifugas'}
                class="flex flex-col overflow-hidden rounded-xl border border-slate-200/80 bg-white p-2 transition hover:border-brand-300 hover:shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
              >
                <div class="flex flex-1 items-center justify-center p-1">
                  <img
                    src={heroThumb.imagePath}
                    alt={heroThumb.imageAlt ?? heroThumb.name}
                    width="120"
                    height="90"
                    class="max-h-20 object-contain"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <p class="mt-1 text-center text-[0.7rem] font-semibold text-brand-950">{heroThumb.name}</p>
              </a>
            )
          }

          {
            servaBrand?.logoPath && (
              <a
                href={`/marcas/${servaBrand.slug}`}
                class="flex flex-col items-center justify-center rounded-xl border border-slate-200/80 bg-white p-3 transition hover:border-brand-300 hover:shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
              >
                <img
                  src={servaBrand.logoPath}
                  alt={servaBrand.logoAlt ?? 'SERVA Electrophoresis'}
                  width="120"
                  height="48"
                  class="max-h-12 w-auto object-contain"
                  loading="lazy"
                  decoding="async"
                />
                <p class="mt-2 text-center text-[0.7rem] font-semibold text-brand-950">SERVA</p>
              </a>
            )
          }
        </div>

        <ul class="mt-3 flex flex-wrap gap-2" aria-label="Categorías">
          {
            categoryChips.map((cat) => (
              <li>
                <a
                  href={cat.href}
                  class="inline-block rounded-full bg-brand-50 px-2.5 py-1 text-[0.65rem] font-semibold text-brand-800 transition hover:bg-brand-100"
                >
                  {cat.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 translate-y-px leading-none" aria-hidden="true">
    <svg class="block w-full text-slate-50" viewBox="0 0 1440 48" fill="currentColor" preserveAspectRatio="none">
      <path d="M0,24 C240,48 480,0 720,20 C960,40 1200,8 1440,28 L1440,48 L0,48 Z" />
    </svg>
  </div>
</section>
