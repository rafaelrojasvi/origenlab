---
import type { Product } from '../data/products';
import { getComparisonRows } from '../lib/productShowcase';

interface Props {
  products: Product[];
  class?: string;
}

const { products, class: className = '' } = Astro.props;
const comparisonRows = getComparisonRows(products);
---

{
  comparisonRows.length > 0 && (
    <section class:list={['mt-10', className]} aria-labelledby="comparison-strip-heading">
      <h2 id="comparison-strip-heading" class="text-sm font-bold uppercase tracking-wide text-slate-500">
        Comparación rápida
      </h2>
      <p class="mt-1 text-xs text-slate-500">
        Referencia orientativa según documentación del fabricante; la configuración final se confirma en
        cotización.
      </p>

      <div class="showcase-comparison-table mt-4 hidden overflow-hidden rounded-xl border border-slate-200/80 bg-white md:block">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b border-slate-100 bg-slate-50/80 text-xs font-semibold uppercase tracking-wide text-slate-500">
              <th scope="col" class="px-4 py-3">Modelo</th>
              <th scope="col" class="px-4 py-3">Tipo</th>
              <th scope="col" class="px-4 py-3">Capacidad máx.</th>
              <th scope="col" class="px-4 py-3">Velocidad máx.</th>
              <th scope="col" class="px-4 py-3">Temperatura</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {comparisonRows.map((row) => (
              <tr class="text-slate-700">
                <th scope="row" class="px-4 py-3 font-semibold text-brand-950">
                  {row.model}
                </th>
                <td class="px-4 py-3">{row.tipo}</td>
                <td class="px-4 py-3">{row.capacity}</td>
                <td class="px-4 py-3">{row.speed}</td>
                <td class="px-4 py-3">{row.temperature}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <ul class="mt-4 space-y-3 md:hidden">
        {comparisonRows.map((row) => (
          <li class="rounded-xl border border-slate-200/80 bg-white p-4 text-sm">
            <p class="font-semibold text-brand-950">{row.model}</p>
            <dl class="mt-2 grid grid-cols-1 gap-2">
              <div class="flex justify-between gap-3 border-b border-slate-50 pb-2">
                <dt class="text-slate-500">Tipo</dt>
                <dd class="text-right font-medium text-slate-800">{row.tipo}</dd>
              </div>
              <div class="flex justify-between gap-3 border-b border-slate-50 pb-2">
                <dt class="text-slate-500">Capacidad máx.</dt>
                <dd class="text-right font-medium text-slate-800">{row.capacity}</dd>
              </div>
              <div class="flex justify-between gap-3 border-b border-slate-50 pb-2">
                <dt class="text-slate-500">Velocidad máx.</dt>
                <dd class="text-right font-medium text-slate-800">{row.speed}</dd>
              </div>
              <div class="flex justify-between gap-3">
                <dt class="text-slate-500">Temperatura</dt>
                <dd class="text-right font-medium text-slate-800">{row.temperature}</dd>
              </div>
            </dl>
          </li>
        ))}
      </ul>
    </section>
  )
}
