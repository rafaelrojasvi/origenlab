---
import type { Product } from '../data/products';
import { productPageHref } from '../lib/catalog';
import {
  homePreviewAccessibleLabel,
  homePreviewFeaturedProduct,
  homePreviewSupportingProducts,
  homePreviewTypeLabel,
} from '../lib/homeProductPreview';

interface Props {
  products: readonly Product[];
}

const { products } = Astro.props;

const featured = homePreviewFeaturedProduct(products);
const supporting = homePreviewSupportingProducts(products, featured);

const linkBase =
  'rounded-xl border border-slate-200/90 bg-white transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2';
---

<div class="mt-4 flex flex-col gap-3 md:flex-row md:items-stretch md:gap-4" aria-label="Vista previa de centrífugas Ortoalresa">
  {
    featured && featured.imagePath && productPageHref(featured) && (
      <a
        href={productPageHref(featured)}
        class:list={[linkBase, 'flex flex-col p-4 md:min-w-0 md:flex-[1.05]']}
        aria-label={homePreviewAccessibleLabel(featured, homePreviewTypeLabel(featured))}
      >
        <div class="flex min-h-[8.5rem] flex-1 items-center justify-center rounded-lg bg-gradient-to-b from-slate-50 to-white p-4 md:min-h-[10rem]">
          <img
            src={featured.imagePath}
            alt={featured.imageAlt ?? `Centrífuga Ortoalresa ${featured.name}`}
            width="280"
            height="220"
            class="max-h-28 w-auto object-contain md:max-h-32"
            loading="lazy"
            decoding="async"
          />
        </div>
        <p class="mt-3 text-base font-bold leading-snug text-brand-950">{featured.name}</p>
        <p class="mt-1 text-sm leading-snug text-slate-600">{homePreviewTypeLabel(featured)}</p>
      </a>
    )
  }

  <ul class="flex flex-col gap-2 md:min-w-0 md:flex-1 md:justify-center" role="list">
    {
      supporting.map((product) => {
        const href = productPageHref(product);
        const typeLabel = homePreviewTypeLabel(product);
        if (!href || !product.imagePath) return null;

        return (
          <li>
            <a
              href={href}
              class:list={[linkBase, 'flex items-center gap-3 p-2.5 sm:p-3']}
              aria-label={homePreviewAccessibleLabel(product, typeLabel)}
            >
              <div
                class="flex h-[4.5rem] w-[4.5rem] shrink-0 items-center justify-center rounded-lg bg-slate-50"
              >
                <img
                  src={product.imagePath}
                  alt={product.imageAlt ?? `Centrífuga Ortoalresa ${product.name}`}
                  width="72"
                  height="72"
                  class="h-[3.25rem] w-[3.25rem] object-contain"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="flex-1 leading-snug">
                <p class="text-sm font-semibold text-brand-950">{product.name}</p>
                <p class="mt-0.5 text-xs text-slate-500">{typeLabel}</p>
              </div>
            </a>
          </li>
        );
      })
    }
  </ul>
</div>
