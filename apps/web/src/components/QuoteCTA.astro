---
import { whatsappUrl } from '../data/contact';
import { buildQuoteMailtoUrl } from '../lib/whatsapp';
import { ctaLabels } from '../lib/ctaLabels';

const mailtoHref = buildQuoteMailtoUrl();

interface Props {
  title?: string;
  description?: string;
  class?: string;
}

const {
  title = 'Solicitar cotización o información',
  description = 'Escríbanos por el canal que prefiera; le orientamos según su laboratorio.',
  class: className = '',
} = Astro.props;
---

<section
  class={`rounded-2xl border border-brand-200 bg-gradient-to-br from-brand-50 to-white px-6 py-10 shadow-sm ${className}`}
  aria-labelledby="quote-cta-heading"
>
  <h2 id="quote-cta-heading" class="text-lg font-bold text-brand-950">
    {title}
  </h2>
  <p class="mt-2 text-sm text-slate-600">{description}</p>
  <div class="mt-6 flex flex-wrap gap-3">
    <a
      href={mailtoHref}
      class="btn-primary"
      aria-label={ctaLabels.solicitarCotizacion}
    >
      {ctaLabels.solicitarCotizacion}
    </a>
    <a
      href={whatsappUrl()}
      class="btn-whatsapp"
      target="_blank"
      rel="noopener noreferrer"
      aria-label={ctaLabels.whatsapp}
    >
      {ctaLabels.whatsapp}
    </a>
    <a href="/contacto" class="btn-outline-dark">Contacto y horario</a>
  </div>
</section>
