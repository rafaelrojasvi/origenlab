---
const categories = [
  {
    slug: 'alimentos',
    title: 'Alimentos',
    description:
      'Equipamiento para análisis, control e inocuidad en alimentos y procesos asociados.',
    chips: ['Calidad', 'Análisis', 'Proceso'] as const,
    icon: 'A',
  },
  {
    slug: 'control-de-calidad',
    title: 'Control de calidad',
    description:
      'Instrumentación y equipos para ensayos, preparación de muestras y control interno.',
    chips: ['QC', 'Muestras', 'Ensayos'] as const,
    icon: 'QC',
  },
  {
    slug: 'laboratorio-clinico',
    title: 'Laboratorio clínico',
    description:
      'Equipamiento para laboratorios clínicos según requerimiento, configuración y cotización.',
    chips: ['Clínico', 'Preparación', 'Soporte'] as const,
    icon: 'LC',
  },
] as const;
---

<section class="home-section" aria-labelledby="home-categories-heading">
  <header class="max-w-2xl">
    <h2 id="home-categories-heading" class="text-2xl font-bold tracking-tight text-brand-950 md:text-3xl">
      Explore por necesidad del laboratorio
    </h2>
    <p class="mt-3 text-slate-600">
      Tres áreas de trabajo. Elija la que se acerque a su laboratorio y solicite orientación al cotizar.
    </p>
  </header>

  <ul class="mt-10 grid gap-6 md:grid-cols-3">
    {
      categories.map((cat) => (
        <li class="flex">
          <article class="group home-category-card">
            <div
              class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-brand-600 to-brand-800 text-sm font-bold text-white shadow-sm"
              aria-hidden="true"
            >
              {cat.icon}
            </div>
            <h3 class="mt-4 text-lg font-bold text-brand-950">{cat.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{cat.description}</p>
            <ul class="mt-4 flex flex-wrap gap-1.5" aria-label={`Ámbitos ${cat.title}`}>
              {cat.chips.map((chip) => (
                <li>
                  <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600">
                    {chip}
                  </span>
                </li>
              ))}
            </ul>
            <a
              href={`/categorias/${cat.slug}`}
              class="mt-5 inline-flex text-sm font-bold text-brand-700 transition group-hover:text-brand-800"
            >
              Ver categoría →
            </a>
          </article>
        </li>
      ))
    }
  </ul>
</section>
