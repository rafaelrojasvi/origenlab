---
import type { Product } from '../data/products';
import { buildWhatsAppQuoteUrl } from '../lib/whatsapp';
import { ctaLabels } from '../lib/ctaLabels';

interface Props {
  product: Product;
  brandName: string;
  brandHref: string;
  brandLineLabel?: string;
}

const { product, brandName, brandHref, brandLineLabel = 'Ver línea' } = Astro.props;

const quoteHref = buildWhatsAppQuoteUrl({
  productName: product.name,
  brandName,
});
const cardClass = 'card-elevated flex h-full flex-col border-l-4 border-l-brand-500';
---

<article class={cardClass}>
  {product.equipmentType && (
    <p class="text-xs font-medium text-slate-500">{product.equipmentType}</p>
  )}
  <h3 class="mt-1 font-semibold text-brand-950">{product.name}</h3>
  {product.sku && (
    <p class="mt-1 text-xs font-medium uppercase tracking-wide text-slate-500">Ítem {product.sku}</p>
  )}
  <p class="mt-2 text-sm leading-relaxed text-slate-600">{product.summary}</p>
  {product.application && (
    <p class="mt-2 text-sm text-slate-600">{product.application}</p>
  )}
  <p class="mt-3 text-xs leading-relaxed text-slate-500">{product.commercialNote}</p>
  <div class="mt-auto flex flex-col gap-2 pt-4 sm:flex-row">
    <a href={brandHref} class="btn-outline-dark flex-1 text-center text-sm">
      {brandLineLabel}
    </a>
    <a
      href={quoteHref}
      class="btn-whatsapp flex-1 text-center text-sm"
      target="_blank"
      rel="noopener noreferrer"
    >
      {ctaLabels.whatsapp}
    </a>
  </div>
</article>
